# Copy to .env on a server or local machine when defaults need changing.

# Host port exposed by docker compose.
APP_PORT=8000

# SQLite path inside the container. The default is backed by ./data on the host.
DB_PATH=/app/data/krisha.sqlite3

# WAL is better for the VPS because the app, refresh job, and bot can read/write concurrently.
SQLITE_JOURNAL_MODE=WAL

# Planned refresh sizes.
DAILY_REFRESH_PAGES=50
WEEKLY_REFRESH_PAGES=200

# Public domain for HTTPS/Caddy setup after DNS points to the VPS.
# Example: APP_DOMAIN=example.com
APP_DOMAIN=

# Public website URL used in Telegram bot messages.
APP_PUBLIC_URL=https://kvartiry-ai.kz

# Telegram bot settings. Create the bot with @BotFather.
# TELEGRAM_BOT_TOKEN is required only when starting the bot profile.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_DIGEST_HOUR_ASTANA=9

# Required before POST /refresh-listings will run.
ADMIN_TOKEN=change-me
