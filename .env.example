# Copy to .env on a server or local machine when defaults need changing.

# Host port exposed by docker compose.
APP_PORT=8000

# SQLite path inside the container. The default is backed by ./data on the host.
DB_PATH=/app/data/krisha.sqlite3

# DELETE is more compatible with Docker bind mounts on Windows.
SQLITE_JOURNAL_MODE=DELETE

# Planned refresh sizes.
DAILY_REFRESH_PAGES=50
WEEKLY_REFRESH_PAGES=200

# Public domain for future HTTPS/Caddy setup, e.g. example.com.
APP_DOMAIN=

# Required before POST /refresh-listings will run.
ADMIN_TOKEN=change-me
